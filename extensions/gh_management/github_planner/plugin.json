{
  "name": "github_planner",
  "version": "1.1",
  "description": "GitHub issue planning, analysis, and project context management",
  "entry": "extensions.gh_management.github_planner",
  "entry_command": "gh-plan.md",
  "commands_dir": "commands",
  "commands": [
    "gh-plan.md",
    "gh-plan-list.md",
    "gh-plan-create.md",
    "gh-plan-analyze.md",
    "gh-plan-unload.md",
    "gh-plan-setup.md",
    "gh-plan-auth.md",
    "current-stat.md",
    "gh-docs.md",
    "skill-map.md",
    "cmd-map.md"
  ],
  "requires_env": ["GITHUB_REPO"],
  "optional_env": ["GITHUB_TOKEN"],
  "conversation_triggers": [
    "let's plan",
    "analyze my repo",
    "create a github issue",
    "track this as an issue",
    "push this to github",
    "draft an issue",
    "what issues do we have",
    "plan some work",
    "let's break this down into issues"
  ]
}
