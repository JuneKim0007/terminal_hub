{
  "name": "prompt_debugger",
  "version": "1.0",
  "description": "Inspect terminal-hub prompts and caches currently held in the session",
  "slash_command": "inspect",
  "tool": "get_session_state",
  "expandable": true,
  "items_tracked": [
    {"key": "analyzer_snapshot", "label": "Analyzer snapshot", "path": "hub_agents/extensions/gh_planner/analyzer_snapshot.json", "type": "cache"},
    {"key": "project_summary", "label": "Project summary", "path": "hub_agents/extensions/gh_planner/project_summary.md", "type": "prompt"},
    {"key": "project_detail", "label": "Project detail", "path": "hub_agents/extensions/gh_planner/project_detail.md", "type": "prompt"},
    {"key": "issues", "label": "Tracked issues", "path": "hub_agents/issues/", "type": "cache"}
  ]
}
