{
  "_comment": "Per-command cache lifecycle policy. unload[] items are cleared when the command completes. keep[] items survive unload. Persistent disk state (issues, project_summary.md, project_detail.md, config.yaml, .env) is never touched.",
  "cache_keys": {
    "analysis_cache":       "In-memory repo analysis results (_ANALYSIS_CACHE)",
    "project_docs_cache":   "In-memory project summary + detail docs (_PROJECT_DOCS_CACHE)",
    "file_tree_cache":      "In-memory file tree per repo (_FILE_TREE_CACHE)",
    "session_header_cache": "In-memory session header per root (_SESSION_HEADER_CACHE)",
    "label_cache":          "In-memory GitHub label list per repo (_LABEL_CACHE)",
    "repo_cache":           "In-memory repo string per root (_REPO_CACHE)",
    "analyzer_snapshot":    "Disk: hub_agents/extensions/gh_planner/analyzer_snapshot.json",
    "file_hashes":          "Disk: hub_agents/extensions/gh_planner/file_hashes.json",
    "file_tree":            "Disk: hub_agents/extensions/gh_planner/file_tree.json",
    "github_local_config":  "Disk: hub_agents/extensions/gh_planner/github_local_config.json",
    "docs_strategy":        "Disk: hub_agents/extensions/gh_planner/docs_strategy.json",
    "github_repo":          "Persistent: GITHUB_REPO in hub_agents/.env — never cleared by unload",
    "workspace_config":     "Persistent: hub_agents/config.yaml — never cleared by unload",
    "preferences":          "Persistent: user preferences in hub_agents/config.yaml — never cleared by unload",
    "project_summary":      "Persistent: hub_agents/extensions/gh_planner/project_summary.md",
    "project_detail":       "Persistent: hub_agents/extensions/gh_planner/project_detail.md",
    "issue_files":          "Persistent: hub_agents/issues/*.md — never cleared by unload"
  },
  "always_keep": [
    "workspace_config",
    "github_repo",
    "preferences",
    "issue_files",
    "project_summary",
    "project_detail"
  ],
  "commands": {
    "github-planner": {
      "description": "Full integrated planning flow — heavy analysis + docs loaded",
      "unload": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "label_cache",
        "analyzer_snapshot",
        "file_hashes",
        "file_tree",
        "github_local_config"
      ],
      "keep": [
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "github-planner/analyze": {
      "description": "Repo analysis only — clears analysis artifacts, keeps docs",
      "unload": [
        "analysis_cache",
        "file_tree_cache",
        "session_header_cache",
        "analyzer_snapshot",
        "file_hashes",
        "file_tree"
      ],
      "keep": [
        "project_docs_cache",
        "label_cache",
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "github-planner/create-issue": {
      "description": "Single issue creation — lightweight, only clear session header",
      "unload": [
        "session_header_cache"
      ],
      "keep": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "label_cache",
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "github-planner/list-issues": {
      "description": "Issue listing — nothing to unload, stateless read",
      "unload": [],
      "keep": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "label_cache",
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "github-planner/setup": {
      "description": "Workspace setup — clears repo cache so new repo is picked up",
      "unload": [
        "repo_cache",
        "label_cache",
        "github_local_config"
      ],
      "keep": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "github-planner/auth": {
      "description": "Auth recovery — no caches to clear",
      "unload": [],
      "keep": [
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "github-planner/unload": {
      "description": "Manual full unload — clears everything except persistent config",
      "unload": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "label_cache",
        "repo_cache",
        "analyzer_snapshot",
        "file_hashes",
        "file_tree",
        "github_local_config",
        "docs_strategy"
      ],
      "keep": [
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "create-github-repo": {
      "description": "GitHub repo creation — keep repo_cache warm after linking",
      "unload": [
        "label_cache",
        "github_local_config"
      ],
      "keep": [
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences",
        "project_docs_cache"
      ]
    },
    "current-stat": {
      "description": "Status snapshot — read-only, nothing to unload",
      "unload": [],
      "keep": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "label_cache",
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-implementation": {
      "description": "Implementation entry — unload analysis caches, keep project docs and issues",
      "unload": ["analysis_cache", "project_docs_cache", "file_tree_cache", "session_header_cache", "label_cache", "analyzer_snapshot", "file_hashes", "file_tree"],
      "keep": ["repo_cache", "github_repo", "workspace_config", "preferences"]
    },
    "gh-implementation/implement": {
      "description": "Implement a single issue — no additional unloads",
      "unload": [],
      "keep": ["repo_cache", "github_repo", "workspace_config", "preferences"]
    },
    "gh-implementation/session-knowledge": {
      "description": "View/change session flags — keep everything",
      "unload": [],
      "keep": ["repo_cache", "github_repo", "workspace_config", "preferences"]
    }
  }
}
