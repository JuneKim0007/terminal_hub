{
  "_comment": "Per-command cache lifecycle policy. unload[] items are cleared when the command completes. keep[] items survive unload. Persistent disk state (issues, project_summary.md, project_detail.md, config.yaml, .env) is never touched.",
  "cache_keys": {
    "analysis_cache":       "repo file analysis used for smarter issue suggestions",
    "project_docs_cache":   "your project summary and design notes",
    "file_tree_cache":      "repo directory structure map",
    "session_header_cache": "quick session status snapshot",
    "label_cache":          "GitHub labels for this repo",
    "milestone_cache":      "GitHub milestones for this repo",
    "repo_cache":           "your linked repo name",
    "analyzer_snapshot":    "saved analysis snapshot — which files were scanned",
    "file_hashes":          "file content hashes to skip re-reading unchanged files",
    "file_tree":            "saved file tree from last analysis",
    "github_local_config":  "cached GitHub API responses for this session",
    "docs_strategy":        "how docs were generated last time",
    "github_repo":          "your linked GitHub repository",
    "workspace_config":     "workspace mode and settings",
    "preferences":          "your saved preferences",
    "project_summary":      "project goals, tech stack, and milestones",
    "project_detail":       "per-feature design notes and conventions",
    "issue_files":          "all your tracked issues"
  },
  "always_keep": [
    "workspace_config",
    "github_repo",
    "preferences",
    "issue_files",
    "project_summary",
    "project_detail"
  ],
  "commands": {
    "gh-plan": {
      "description": "Full integrated planning flow — heavy analysis + docs loaded",
      "unload": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "label_cache",
        "milestone_cache",
        "analyzer_snapshot",
        "file_hashes",
        "file_tree",
        "github_local_config"
      ],
      "keep": [
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-plan-analyze": {
      "description": "Repo analysis only — clears analysis artifacts, keeps docs",
      "unload": [
        "analysis_cache",
        "file_tree_cache",
        "session_header_cache",
        "analyzer_snapshot",
        "file_hashes",
        "file_tree"
      ],
      "keep": [
        "project_docs_cache",
        "label_cache",
        "milestone_cache",
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-plan-create": {
      "description": "Single issue creation — lightweight, only clear session header",
      "unload": [
        "session_header_cache"
      ],
      "keep": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "label_cache",
        "milestone_cache",
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-plan-list": {
      "description": "Issue listing — nothing to unload, stateless read",
      "unload": [],
      "keep": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "label_cache",
        "milestone_cache",
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-plan-setup": {
      "description": "Workspace setup — clears repo cache so new repo is picked up",
      "unload": [
        "repo_cache",
        "label_cache",
        "github_local_config"
      ],
      "keep": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-plan-auth": {
      "description": "Auth recovery — no caches to clear",
      "unload": [],
      "keep": [
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-plan-unload": {
      "description": "Manual full unload — clears everything except persistent config",
      "unload": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "label_cache",
        "milestone_cache",
        "repo_cache",
        "analyzer_snapshot",
        "file_hashes",
        "file_tree",
        "github_local_config",
        "docs_strategy"
      ],
      "keep": [
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-plan-settings": {
      "description": "View/change planning preferences — keep all caches intact",
      "unload": [],
      "keep": [
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "create-github-repo": {
      "description": "GitHub repo creation — keep repo_cache warm after linking",
      "unload": [
        "label_cache",
        "github_local_config"
      ],
      "keep": [
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences",
        "project_docs_cache"
      ]
    },
    "current-stat": {
      "description": "Status snapshot — read-only, nothing to unload",
      "unload": [],
      "keep": [
        "analysis_cache",
        "project_docs_cache",
        "file_tree_cache",
        "session_header_cache",
        "label_cache",
        "repo_cache",
        "github_repo",
        "workspace_config",
        "preferences"
      ]
    },
    "gh-implementation": {
      "description": "Implementation entry — unload analysis caches, keep project docs and issues",
      "unload": ["analysis_cache", "project_docs_cache", "file_tree_cache", "session_header_cache", "label_cache", "milestone_cache", "analyzer_snapshot", "file_hashes", "file_tree"],
      "keep": ["repo_cache", "github_repo", "workspace_config", "preferences"]
    },
    "gh-implementation/implement": {
      "description": "Implement a single issue — no additional unloads",
      "unload": [],
      "keep": ["repo_cache", "github_repo", "workspace_config", "preferences"]
    },
    "gh-implementation/session-knowledge": {
      "description": "View/change session flags — keep everything",
      "unload": [],
      "keep": ["repo_cache", "github_repo", "workspace_config", "preferences"]
    },
    "init": {
      "description": "Project bootstrap — stateless operation, nothing to unload",
      "unload": [],
      "keep": ["repo_cache", "github_repo", "workspace_config", "preferences", "project_summary", "project_detail", "issue_files"]
    }
  }
}
